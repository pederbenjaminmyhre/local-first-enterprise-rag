<Window x:Class="EnterpriseRag.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Local-First Enterprise RAG"
        Height="720" Width="1080"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Local-First Enterprise RAG"
                               FontSize="18" FontWeight="Bold" Foreground="White"
                               FontFamily="Segoe UI" />
                    <TextBlock Text="SQL Server 2025 Vector Search + Ollama LLM"
                               FontSize="12" Foreground="#94A3B8"
                               FontFamily="Segoe UI" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                        <Setter Property="Fill" Value="#F59E0B" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#94A3B8"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SEARCH BAR ═══ -->
        <Border Grid.Row="1" Padding="24,16" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBox}"
                         Margin="0,0,12,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Style="{StaticResource FilterComboBox}"
                          Margin="0,0,8,0" />

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Colors}"
                          SelectedItem="{Binding SelectedColor}"
                          Style="{StaticResource FilterComboBox}"
                          Margin="0,0,12,0" />

                <Button Grid.Column="3"
                        Content="Search"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,6,0" />

                <Button Grid.Column="4"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="2" Margin="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- AI Response Panel -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="AI RESPONSE"
                               Style="{StaticResource SectionHeader}" />

                    <!-- Loading indicator -->
                    <StackPanel DockPanel.Dock="Top"
                                Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,0,8">
                        <ProgressBar IsIndeterminate="True" Height="3"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource SurfaceBrush}"
                                     BorderThickness="0" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding Answer}"
                                   Style="{StaticResource BaseText}"
                                   TextWrapping="Wrap"
                                   LineHeight="24" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Sources Panel -->
            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SOURCES"
                               Style="{StaticResource SectionHeader}" />

                    <ListBox ItemsSource="{Binding Sources}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SourceItem}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding EnglishProductName}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Background="#DBEAFE"
                                                    CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding SimilarityScore, StringFormat={}{0:F3}}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#1E40AF" />
                                            </Border>
                                        </Grid>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0">
                                            <Run Text="{Binding ProductSubcategoryName, TargetNullValue=N/A}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding Color, TargetNullValue=N/A}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding EnglishDescription}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" MaxHeight="48"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="{StaticResource PrimaryBrush}" Padding="24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ElapsedTime}"
                           Foreground="#94A3B8" FontSize="12" FontFamily="Segoe UI"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Ollama + SQL Server 2025 + .NET 9"
                           Foreground="#475569" FontSize="11" FontFamily="Segoe UI"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
